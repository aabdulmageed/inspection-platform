# Copy to .env and adjust as needed.

# --- Postgres ---
POSTGRES_USER=ip
POSTGRES_PASSWORD=ip_dev_password
POSTGRES_DB=inspection
DATABASE_URL=postgresql://ip:ip_dev_password@localhost:5432/inspection?schema=public

# --- API ---
API_PORT=4000
JWT_SECRET=dev_jwt_secret_change_me
JWT_EXPIRES_IN=15m
PDF_SERVICE_URL=http://localhost:4100

# --- Object storage (MinIO, S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=inspection-photos

# --- Mail (Mailpit dev defaults) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- Queue ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Security ---
WEB_ORIGIN=http://localhost:3000
JWT_REFRESH_SECRET=dev_refresh_secret_change_me

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
