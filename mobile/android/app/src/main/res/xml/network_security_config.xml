<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow plain http to the dev API on the emulator host (10.0.2.2) / localhost. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
    <!-- Trust CRC's self-signed ingress CA for the OpenShift route hosts
         (api / web / minio are all *.apps-crc.testing). -->
    <domain-config>
        <domain includeSubdomains="true">apps-crc.testing</domain>
        <trust-anchors>
            <certificates src="@raw/crc_ca"/>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
</network-security-config>
